rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Operations — only the owning user may read/write
    match /operations/{opId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // Custom procedure types — scoped per user
    match /procedureTypes/{typeId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // User settings — document ID must match auth UID
    match /userSettings/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Consent records — document ID must match auth UID
    match /consents/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Support requests — users can only create their own; read/update/delete via admin console
    match /supportRequests/{docId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Support rate-limit counters — per-user doc scoped by UID
    match /supportLimits/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
