rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the caller a paid Pro subscriber? ──────────────────────────
    function isPro() {
      return request.auth.token.stripeRole == "pro";
    }

    // Operations — only the owning user with a Pro subscription may sync
    match /operations/{opId} {
      allow read, delete: if request.auth != null
        && resource.data.userId == request.auth.uid
        && isPro();
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && isPro();
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && isPro();
    }

    // Custom procedure types — Pro subscription required
    match /procedureTypes/{typeId} {
      allow read, delete: if request.auth != null
        && resource.data.userId == request.auth.uid
        && isPro();
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && isPro();
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && isPro();
    }

    // User settings — any signed-in user (specialty sync for free accounts)
    match /userSettings/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Consent records — document ID must match auth UID
    match /consents/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Support requests — users can only create their own; read/update/delete via admin console
    match /supportRequests/{docId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Support rate-limit counters — per-user doc scoped by UID
    match /supportLimits/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── Stripe Extension collections ─────────────────────────────────────────

    // Customer records — users can read their own, write checkout sessions
    match /customers/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      match /checkout_sessions/{id} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /subscriptions/{id} {
        allow read: if request.auth != null && request.auth.uid == uid;
      }

      match /payments/{id} {
        allow read: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Products & prices — publicly readable (synced from Stripe Dashboard)
    match /products/{id} {
      allow read: if true;

      match /prices/{priceId} {
        allow read: if true;
      }

      match /tax_rates/{taxId} {
        allow read: if true;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
