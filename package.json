{
  "name": "theatrelog",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "size": "size-limit",
    "analyze": "ANALYZE=true npm run build",
    "lhci": "lhci autorun",
    "icons": "node scripts/generate-icons.mjs",
    "dev:emulator": "concurrently -k -n emu,app -c blue,green \"npm run emulator:start\" \"wait-on http://127.0.0.1:4000 && npm run emulator:seed && vite --mode emulator\"",
    "emulator:start": "firebase emulators:start --project demo-britops --only auth,firestore --import=.emulator-data --export-on-exit=.emulator-data",
    "emulator:seed": "tsx --tsconfig tsconfig.scripts.json scripts/seed-emulator.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "firebase": "^12.10.0",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.25.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "fake-indexeddb": "^6.2.5",
    "firebase-admin": "^13.4.0",
    "globals": "^16.0.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "size-limit": "^12.0.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "wait-on": "^8.0.3"
  }
}
